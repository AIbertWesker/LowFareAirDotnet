@{
    ViewData["Title"] = "Szczegóły lotu";
}

<h1>@ViewData["Title"]</h1>

<div id="detailsMessage" class="alert d-none" role="alert"></div>

<div id="detailsCard" class="card d-none">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">FlightId</dt>
            <dd class="col-sm-9" id="dFlightId"></dd>

            <dt class="col-sm-3">Segment</dt>
            <dd class="col-sm-9" id="dSegment"></dd>

            <dt class="col-sm-3">Data</dt>
            <dd class="col-sm-9" id="dDate"></dd>

            <dt class="col-sm-3">Skąd</dt>
            <dd class="col-sm-9" id="dFrom"></dd>

            <dt class="col-sm-3">Dokąd</dt>
            <dd class="col-sm-9" id="dTo"></dd>

            <dt class="col-sm-3">Wylot</dt>
            <dd class="col-sm-9" id="dDepart"></dd>

            <dt class="col-sm-3">Przylot</dt>
            <dd class="col-sm-9" id="dArrive"></dd>

            <dt class="col-sm-3">Posiłek</dt>
            <dd class="col-sm-9" id="dMeal"></dd>

            <dt class="col-sm-3">Czas lotu (h)</dt>
            <dd class="col-sm-9" id="dFlyingTime"></dd>

            <dt class="col-sm-3">Miles</dt>
            <dd class="col-sm-9" id="dMiles"></dd>

            <dt class="col-sm-3">Samolot</dt>
            <dd class="col-sm-9" id="dAircraft"></dd>

            <dt class="col-sm-3">Miejsca zajęte</dt>
            <dd class="col-sm-9" id="dSeats"></dd>
        </dl>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header">Bookowanie</div>
    <div class="card-body">
        <div id="bookingMessage" class="alert d-none" role="alert"></div>

        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label for="seatClass" class="form-label">Klasa</label>
                <select id="seatClass" class="form-select">
                    <option value="0">Economy</option>
                    <option value="1">Business</option>
                    <option value="2">Firstclass</option>
                </select>
            </div>
            <div class="col-md-4 d-grid">
                <button id="bookFlightBtn" type="button" class="btn btn-success">Bookuj lot</button>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a class="btn btn-secondary" href="/Home/Privacy">Powrót do listy</a>
</div>

@section Scripts {
    <script>
        (() => {
            const message = document.getElementById("detailsMessage");
            const card = document.getElementById("detailsCard");
            const bookingMessage = document.getElementById("bookingMessage");
            const seatClassSelect = document.getElementById("seatClass");
            const bookFlightBtn = document.getElementById("bookFlightBtn");

            const setMessage = (text, type) => {
                if (!text) {
                    message.className = "alert d-none";
                    message.textContent = "";
                    return;
                }

                message.className = `alert alert-${type}`;
                message.textContent = text;
            };

            const setText = (id, value) => {
                document.getElementById(id).textContent = value ?? "-";
            };

            const setBookingMessage = (text, type) => {
                if (!text) {
                    bookingMessage.className = "alert d-none";
                    bookingMessage.textContent = "";
                    return;
                }

                bookingMessage.className = `alert alert-${type}`;
                bookingMessage.textContent = text;
            };

            const buildAirport = (airport, city, country, countryCode) => {
                const parts = [airport, city, countryCode ? `(${countryCode})` : null, country].filter(Boolean);
                return parts.join(" - ");
            };

            const loadDetails = async () => {
                const params = new URLSearchParams(window.location.search);
                const flightId = params.get("flightId");
                const segmentNumber = params.get("segmentNumber");
                const flightDate = params.get("flightDate");

                if (!flightId || !segmentNumber || !flightDate) {
                    throw new Error("Brakuje parametrów lotu. Wróć do listy i wybierz lot ponownie.");
                }

                const apiParams = new URLSearchParams({
                    flightId,
                    segmentNumber,
                    flightDate
                });

                const response = await fetch(`/api/flight/details?${apiParams.toString()}`);
                if (!response.ok) {
                    const text = await response.text();
                    throw new Error(text || "Nie udało się pobrać szczegółów lotu.");
                }

                const d = await response.json();

                setText("dFlightId", d.flightId);
                setText("dSegment", d.segmentNumber);
                setText("dDate", d.flightDate);
                setText("dFrom", buildAirport(d.origAirport, d.origCityName, d.origCountry, d.origCountryCode));
                setText("dTo", buildAirport(d.destAirport, d.destCityName, d.destCountry, d.destCountryCode));
                setText("dDepart", d.departTime);
                setText("dArrive", d.arriveTime);
                setText("dMeal", d.mealDescription ? `${d.meal} - ${d.mealDescription}` : d.meal);
                setText("dFlyingTime", d.flyingTime);
                setText("dMiles", d.miles);
                setText("dAircraft", d.aircraft);
                setText("dSeats", `Eco: ${d.economySeatsTaken}, Biz: ${d.businessSeatsTaken}, First: ${d.firstclassSeatsTaken}, Razem: ${d.totalSeatsTaken}`);

                card.classList.remove("d-none");
            };

            const getFlightParamsFromUrl = () => {
                const params = new URLSearchParams(window.location.search);
                const flightId = params.get("flightId");
                const segmentNumber = params.get("segmentNumber");
                const flightDate = params.get("flightDate");

                if (!flightId || !segmentNumber || !flightDate) {
                    throw new Error("Brakuje parametrów lotu. Wróć do listy i wybierz lot ponownie.");
                }

                return { flightId, segmentNumber: Number(segmentNumber), flightDate };
            };

            const bookFlight = async () => {
                const flight = getFlightParamsFromUrl();
                const requestBody = {
                    flightId: flight.flightId,
                    segmentNumber: flight.segmentNumber,
                    flightDate: flight.flightDate,
                    class: Number(seatClassSelect.value)
                };

                const response = await fetch("/api/flight/book", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(requestBody)
                });

                if (!response.ok) {
                    const text = await response.text();
                    throw new Error(text || "Bookowanie nie powiodło się.");
                }

                await response.json();
                await loadDetails();
            };

            bookFlightBtn.addEventListener("click", async () => {
                setBookingMessage("", "");

                try {
                    await bookFlight();
                    setBookingMessage("Lot został zarezerwowany.", "success");
                } catch (err) {
                    setBookingMessage(err.message, "danger");
                }
            });

            (async () => {
                try {
                    await loadDetails();
                    setMessage("", "");
                } catch (err) {
                    card.classList.add("d-none");
                    setMessage(err.message, "danger");
                }
            })();
        })();
    </script>
}
